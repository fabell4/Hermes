# .env.example
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Scheduler ---
SPEEDTEST_INTERVAL_MINUTES=60
RUN_ON_STARTUP=true

# --- Exporters ---
# Comma-separated list of exporters to enable on startup
# Available: csv, prometheus, loki
ENABLED_EXPORTERS=csv

# --- CSV Exporter ---
CSV_LOG_PATH=logs/results.csv

# --- Prometheus Exporter ---
# PROMETHEUS_PORT=8000

# --- Loki Exporter ---
# LOKI_URL=http://loki:3100
# LOKI_JOB_LABEL=speedtest