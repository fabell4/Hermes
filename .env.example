# .env.example
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Timezone ---
# IANA timezone name. Controls log timestamps inside the container.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# --- Scheduler ---
SPEEDTEST_INTERVAL_MINUTES=60
RUN_ON_STARTUP=true

# --- Exporters ---
# Comma-separated list of exporters to enable on startup
# Available: csv, prometheus, loki
ENABLED_EXPORTERS=csv

# --- CSV Exporter ---
CSV_LOG_PATH=logs/results.csv

# --- Prometheus Exporter ---
# Port the /metrics HTTP server listens on inside the container.
# Must match the port mapping in docker-compose.yml.
# PROMETHEUS_PORT=8000

# --- Loki Exporter ---
# Full push URL for your Loki instance.
# When running alongside a Grafana stack, use the service name: http://loki:3100
# LOKI_URL=http://loki:3100
# LOKI_JOB_LABEL=hermes_speedtest

# --- UI Port (docker-compose only) ---
# Host port to expose the Streamlit UI on.
# UI_PORT=8501