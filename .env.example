# .env.example
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Timezone ---
# IANA timezone name. Controls log timestamps inside the container.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# --- Scheduler ---
SPEEDTEST_INTERVAL_MINUTES=60
RUN_ON_STARTUP=true

# --- Exporters ---
# Comma-separated list of exporters to enable on startup
# Available: csv, prometheus, loki, sqlite
ENABLED_EXPORTERS=csv

# --- CSV Exporter ---
CSV_LOG_PATH=logs/results.csv
# CSV_MAX_ROWS=1000        # Maximum number of rows to keep (oldest removed first). 0 = unlimited.
# CSV_RETENTION_DAYS=90   # Delete rows older than this many days. 0 = unlimited.

# --- SQLite Exporter ---
SQLITE_DB_PATH=data/hermes.db
# SQLITE_MAX_ROWS=5000     # Maximum number of rows to keep (oldest removed first). 0 = unlimited.
# SQLITE_RETENTION_DAYS=90 # Delete rows older than this many days. 0 = unlimited.

# --- Prometheus Exporter ---
# Port the /metrics HTTP server listens on inside the container.
# Must match the port mapping in docker-compose.yml.
# PROMETHEUS_PORT=8000

# --- Loki Exporter ---
# Full push URL for your Loki instance.
# When running alongside a Grafana stack, use the service name: http://loki:3100
# LOKI_URL=http://loki:3100
# LOKI_JOB_LABEL=hermes_speedtest

# --- API / UI Port (docker-compose only) ---
# Host port to expose the FastAPI + React frontend on.
# API_PORT=8080

# --- Authentication ---
# When set, all write endpoints (POST /api/trigger, PUT /api/config) require
# an X-Api-Key header with this value. Leave unset to disable auth.
# Use a strong random value, e.g.: openssl rand -hex 32
API_KEY=

# Maximum write requests per API key per 60-second window. 0 = unlimited.
RATE_LIMIT_PER_MINUTE=60

# --- Alerting ---
# Alerting is disabled by default. Set threshold > 0 to enable.
# Number of consecutive failures before sending an alert.
# ALERT_FAILURE_THRESHOLD=0

# Minimum minutes between alerts (to prevent spam).
# ALERT_COOLDOWN_MINUTES=60

# --- Webhook Alerts ---
# POST alerts to a custom webhook URL (JSON payload).
# ALERT_WEBHOOK_URL=https://your-webhook.example.com/alerts

# --- Gotify Alerts ---
# Push notifications via Gotify (https://gotify.net)
# ALERT_GOTIFY_URL=https://gotify.example.com
# ALERT_GOTIFY_TOKEN=your_app_token
# ALERT_GOTIFY_PRIORITY=5

# --- ntfy Alerts ---
# Push notifications via ntfy (https://ntfy.sh)
# ALERT_NTFY_URL=https://ntfy.sh
# ALERT_NTFY_TOPIC=your_topic_name
# ALERT_NTFY_PRIORITY=3
# ALERT_NTFY_TAGS=warning,rotating_light