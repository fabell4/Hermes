{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate config for Hermes. Images are mirrored to the internal registry — Renovate checks upstream versions and opens PRs; re-push to internal registry before merging.",
  "extends": ["config:recommended"],
  "timezone": "America/New_York",
  "schedule": ["every weekend"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,

  "registryAliases": {
    "registry.greenflametech.net": "docker.io"
  },

  "packageRules": [
    {
      "description": "Group all Docker base image updates into one PR",
      "matchManagers": ["dockerfile"],
      "groupName": "docker base images",
      "automerge": false
    },
    {
      "description": "Group all CI container image updates into one PR",
      "matchManagers": ["gitlabci", "github-actions"],
      "matchDepTypes": ["container"],
      "groupName": "CI container images",
      "automerge": false
    },
    {
      "description": "Group all Python dependency updates into one PR",
      "matchManagers": ["pip_requirements"],
      "groupName": "python dependencies",
      "automerge": false
    },
    {
      "description": "Ignore internal runner images — those are managed manually",
      "matchPackageNames": [
        "registry.greenflametech.net/gft-ci-runner",
        "registry.greenflametech.net/gft-python-runner"
      ],
      "enabled": false
    }
  ]
}
